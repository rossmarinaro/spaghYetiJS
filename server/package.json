{
  "name": "spaghYetiJS",
  "version": "1.0.0",
  "main": "main.js",
  "build": {
    "appId": "spaghYetiJS",
    "extends": null,
    "win": {
      "icon": "./public/img/logo.ico",
      "target": "msi"
    }
  },
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "dev": "node ./python/main.js && npm start",
    "start": "nodemon main",
    "buildElectron": "electron .",
    "packageElectron": "electron-packager . --icon=\"./public/img/logo.ico\"",
    "install": "node-gyp rebuild",
    "deploy": "git status && git add . && git commit -am 'update' && git push heroku master && npm run deploy && heroku logs --tail"
  },
  "keywords": [],
