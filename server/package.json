  "license": "ISC",
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.17.2"
  },
  "devDependencies": {
    "electron": "11.2.0",
    "electron-builder": "^22.14.5"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rossmarinaro/spagYetiJS.git"
  },
  "bugs": {
    "url": "https://github.com/rossmarinaro/spagYetiJS/issues"
  },
  "homepage": "https://github.com/rossmarinaro/spagYetiJS#readme",
  "gypfile": true,
  "description": "game"
}
